# まごころ 環境変数テンプレート
# このファイルをコピーして .env を作成し、各自の値を入れてください。
#   cp .env.example .env
# .env は絶対にコミットしないこと（.gitignore 済み）。

# --- LINE (D2-) ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- LLM (D3-) ---
OPENAI_API_KEY=

# --- 音声 STT/TTS (D7-8) ---
STT_API_KEY=
TTS_API_KEY=

# --- 記憶/セッション (W9-) ---
MEM0_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- 課金 (W15-) ---
STRIPE_SECRET_KEY=

# --- 見守り通知の二重化: メール (W13-) ---
