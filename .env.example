# まごころ 環境変数テンプレート
# このファイルをコピーして .env を作成し、各自の値を入れてください。
#   cp .env.example .env
# .env は絶対にコミットしないこと（.gitignore 済み）。

# --- LINE (D2-) ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- LLM (D3-) ---
OPENAI_API_KEY=
# 任意: 使用モデルの上書き（未設定なら gpt-4o-mini）
OPENAI_MODEL=
# 任意: 音声文字起こし(STT)モデルの上書き（未設定なら whisper-1）。OPENAI_API_KEY を共用。
OPENAI_STT_MODEL=
# 任意: 音声合成(TTS)モデル・声の上書き（未設定なら tts-1 / alloy）。OPENAI_API_KEY を共用。
OPENAI_TTS_MODEL=
OPENAI_TTS_VOICE=
# 任意: STT幻聴対策のしきい値（未設定なら 1.0秒 / 0.6）。
STT_MIN_DURATION_SEC=
STT_MAX_NO_SPEECH_PROB=

# --- 音声 STT/TTS (D7-8) ---
# 注: 音声の文字起こし(STT)・合成(TTS)は OpenAI（OPENAI_API_KEY ほか OPENAI_*）を使用。
#     下記は別プロバイダを使う場合の予備枠（現状未使用）。
STT_API_KEY=
TTS_API_KEY=

# --- 公開URL（音声配信。D8-） ---
# 生成音声をLINEに取得させるための公開ベースURL（例: https://xxxx.ngrok-free.app）。
# 未設定ならWebhookリクエストのヘッダ(x-forwarded-proto/host)から導出する。
PUBLIC_BASE_URL=

# --- ffmpeg/ffprobe（音声変換。D8-） ---
# 任意: 実行ファイルの絶対パス。未設定なら Apple Silicon Homebrew の標準位置を使う。
# 環境が違う場合のみ設定（which ffmpeg / which ffprobe で確認）。
FFMPEG_PATH=
FFPROBE_PATH=

# --- 記憶/セッション (W9-) ---
MEM0_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- 課金 (W15-) ---
STRIPE_SECRET_KEY=

# --- 見守り通知の二重化: メール (W13-) ---
MAIL_API_KEY=
