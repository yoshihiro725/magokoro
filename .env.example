# まごころ 環境変数テンプレート
# このファイルをコピーして .env を作成し、各自の値を入れてください。
#   cp .env.example .env
# .env は絶対にコミットしないこと（.gitignore 済み）。

# --- LINE (D2-) ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- LLM (D3-) ---
OPENAI_API_KEY=
# 任意: 使用モデルの上書き（未設定なら gpt-4o-mini）
OPENAI_MODEL=
# 任意: 音声文字起こし(STT)モデルの上書き（未設定なら whisper-1）。OPENAI_API_KEY を共用。
OPENAI_STT_MODEL=

# --- 音声 STT/TTS (D7-8) ---
# 注: D7の音声文字起こし(STT)は OpenAI（OPENAI_API_KEY / OPENAI_STT_MODEL）を使用。
#     下記は別プロバイダを使う場合の予備枠（現状未使用）。
STT_API_KEY=
TTS_API_KEY=

# --- 記憶/セッション (W9-) ---
MEM0_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- 課金 (W15-) ---
STRIPE_SECRET_KEY=

# --- 見守り通知の二重化: メール (W13-) ---
MAIL_API_KEY=
